<!--{{{ EIO_PRI_* -->
   <varlistentry xml:id="constant.eio-pri-min">
    <term>
     <constant>EIO_PRI_MIN</constant>
     (<type>int</type>)
    </term>
    <listitem>
     <simpara>
      Minimale Priorität der Anfrage.
